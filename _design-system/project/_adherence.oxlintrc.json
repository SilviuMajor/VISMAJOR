{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|plain)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'outline' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|full|disabled|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, full, disabled, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetalPlate'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|radius|sheen|style|key|ref|className|style|children)$/]",
        "message": "<MetalPlate> doesn't accept that prop. Declared props: children, tone, radius, sheen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetalPlate'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:aluminium|dark)$/]",
        "message": "<MetalPlate> tone must be one of 'aluminium' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Monogram'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|letters|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Monogram> doesn't accept that prop. Declared props: size, color, letters, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Seal'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|top|bottom|letters|style|key|ref|className|style|children)$/]",
        "message": "<Seal> doesn't accept that prop. Declared props: size, color, top, bottom, letters, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|size|descriptor|color|align|style|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: brand, size, descriptor, color, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='brand'] > Literal[value!=/^(?:gyno|vismajor)$/]",
        "message": "<Wordmark> brand must be one of 'gyno' | 'vismajor'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:start|center)$/]",
        "message": "<Wordmark> align must be one of 'start' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
